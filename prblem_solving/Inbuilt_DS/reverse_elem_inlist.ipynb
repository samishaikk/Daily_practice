    "def reverse_list(lst):\n",
    "    # Your code goes here\n",
    "    \n",
    "    result = []\n",
    "    \n",
    "    for i in range(len(lst) -1,-1,-1):\n",
    "        result.append(lst[i])\n",
    "    \n",
    "    return result\n",
    "    \n",
    "reverse_list(lst=[1,2,3,4,5])"
   ]
