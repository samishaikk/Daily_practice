   "source": [
    "def remove_duplicates(lst):\n",
    "    result = []\n",
    "    \n",
    "    for num in lst:\n",
    "        if num not in result:\n",
    "            result.append(num)\n",
    "        \n",
    "    return result\n",
    "\n",
    "\n",
    "print(remove_duplicates(lst=[1,2,3,3,4,4,5]))\n",
    "print(remove_duplicates(lst=[1,2,3,4,5]))"
   ]
