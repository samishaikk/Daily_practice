    "def check_unique(lst):\n",
    "    # Your code goes here\n",
    "    \n",
    "    result = set()\n",
    "    \n",
    "    for num in lst:\n",
    "        if num in result:\n",
    "            return False\n",
    "            \n",
    "        result.add(num)\n",
    "    \n",
    "    return True\n",
    "    \n",
    "check_unique(lst=[1,23,4,5,5])"
