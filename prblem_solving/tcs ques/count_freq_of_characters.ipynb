   "source": [
    "from collections import Counter\n",
    "\n",
    "def char_freq(s):\n",
    "    \n",
    "    freq = Counter(s)\n",
    "    \n",
    "    for ch, count in sorted(freq.items()):\n",
    "        print(f\"{ch} = {count}\")\n",
    "        \n",
    "    for ch in freq.items():\n",
    "        print(ch)\n",
    "        \n",
    "char_freq(s='aabbcc')"
   ]
  },
